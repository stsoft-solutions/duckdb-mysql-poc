{
  logger: {
    level: "info",
    pretty: true,
    pretty_options: {
      colorize: true,
      ignore: "pid,hostname,service,environment,level,time",
      single_line: true,
      hide_object: true,
      hide_error_object: false,
    }
  },
  database: {
    default_timeout: 30000,
    connections: {
      analytics: {
        kind: "duckdb",
        path: ":memory:",
        // access_mode: "read_write"  // optional: "read_write" | "read_only"
      },
      // mysql_main: {
      //   kind: "mysql",
      //   host: "localhost",
      //   port: 3306,
      //   username: "user",
      //   password: "pass",
      //   database: "mydb",
      //   pool_size: 10
      // },
      // mariadb_main: {
      //   kind: "mariadb",
      //   host: "localhost",
      //   port: 3306,
      //   username: "user",
      //   password: "pass",
      //   database: "mydb",
      //   pool_size: 10
      // }
    }
  },
  export_service: {
    db_connection: {
      host: "localhost",
      port: 5432,
      username: "user",
      password: "pass",
      database: "mydb"
    },
    tables: [
      {
        schema: "public",
        table: "my_table",
        timespan_column: {
          name: "time",
          time_format: "timestamp"
        }
      }
    ]
  }
}