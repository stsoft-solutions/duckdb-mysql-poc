{
  logger: {
    level: "trace",
    pretty: true,
    pretty_options: {
      colorize: true,
      ignore: "pid,hostname,service,environment,level,time",
      single_line: true,
      hide_object: false,
      hide_error_object: false,
    }
  },
  database: {
    default_timeout: 30000,
    connections: {
      processing: {
        kind: "duckdb",
        storage: {
          mode: "memory",
          // mode: "file",
          // path: "./data/processing.duckdb",
        },
        // access_mode: "read_write" // optional: "read_write" | "read_only"
        initialization: {
          settings: {
            threads: 4,
            memory_limit: "2GB",
            mysql_experimental_filter_pushdown: true,
            mysql_tinyint1_as_boolean: false,
          },
        },
        extensions: [
          "mysql"
        ],
        attachments: [
          {
            type: "mysql",
            alias: "mysql_db",
            read_only: true,
            host: "localhost",
            port: 3306,
            username: "bugaga",
            password: "bugaga",
            database: "stat_ms",
          }
        ],
      },
      // mysql_main: {
      //   kind: "mysql",
      //   host: "localhost",
      //   port: 3306,
      //   username: "user",
      //   password: "pass",
      //   database: "mydb",
      //   pool_size: 10
      // },
      //      source: {
      //        kind: "mariadb",
      //        host: "localhost",
      //        port: 3306,
      //        username: "user",
      //        password: "pass",
      //        database: "mydb",
      //        pool_size: 10
      //      }
    }
  },
  export_service: {
    chunk_size: 250000,
    db_connection: "processing",
    attached_db_alias: "mysql_db",
    storage_path: "../local_storage/export",
    temp_path: "../local_storage/temp",
  }
}
