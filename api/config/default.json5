{
  logger: {
    level: "info",
    service_name: "api",
    environment: "development",
    pretty: true,
    pretty_options: {
      colorize: true,
      ignore: "pid,hostname,service,environment,level,time",
      single_line: true,
      hide_object: false,
      hide_error_object: false,
    }
  },
  api: {
    host: "127.0.0.1",
    port: 3000,
    // Override in local.json5: api_key: "your-real-secret-key"
    api_key: "dev-secret-key",
  }
}

