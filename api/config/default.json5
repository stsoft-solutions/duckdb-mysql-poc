{
  logger: {
    level: "info",
    service_name: "api",
    environment: "development",
    pretty: true,
    pretty_options: {
      colorize: true,
      ignore: "pid,hostname,service,environment,level,time",
      single_line: true,
      hide_object: false,
      hide_error_object: false,
    }
  },
  api: {
    host: "127.0.0.1",
    port: 3000,
    // Optional runtime response schema validation (off by default).
    validate_responses: false,
    rate_limit: {
      enabled: true,
      auth_endpoints: {
        window_ms: 60000,
        max_per_ip: 20,
        max_per_consumer: 60,
      },
      sensitive_endpoints: {
        window_ms: 60000,
        max_per_ip: 10,
        max_per_consumer: 30,
      },
    },
    // Backward-compatible single key; prefer api_consumers below.
    api_key: "dev-secret-key",
    api_consumers: [
      {
        name: "reader-client",
        api_key: "dev-reader-key",
        roles: ["reader"],
      },
      {
        name: "analyst-client",
        api_key: "dev-analyst-key",
        roles: ["reader", "analyst"],
      },
      {
        name: "admin-client",
        api_key: "dev-admin-key",
        roles: ["reader", "analyst", "admin"],
      },
    ],
  }
}

