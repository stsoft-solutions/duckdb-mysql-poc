{
  "name": "api",
  "version": "1.0.0",
  "description": "Initial Fastify REST API service with TypeScript, Zod, tsyringe, and OpenAPI",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/**/*.test.ts"
  },
  "keywords": [
    "fastify",
    "typescript",
    "zod",
    "openapi",
    "tsyringe"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/config": "^3.3.5",
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@duckdb-poc/shared-infra": "file:../shared-infra",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "ajv": "^8.17.1",
    "config": "^4.4.1",
    "fastify": "^5.8.5",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  }
}
