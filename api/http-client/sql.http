###
#"sql": "select avg(close_time) AS avg_close from order_mt4 as o join account_opt a on o.source = a.source and o.login = a.login where o.client_id = 100600"
# This query calculates the average close time of orders from the `order_mt4` table that are associated with a specific client ID (100600). It performs a join with the `account_opt` table to match orders based on their source and login information. The result will provide the average close time for orders that belong to the specified client, giving insight into how long it takes for their orders to close on average.
# DuckDB elapsed time: 3524 ms
# MariaDB elapsed time: 41 s 32 ms
POST {{url}}/v1/sql/query
accept: application/json
x-api-key: {{apiKey}}
Content-Type: application/json

{
  "sql": "select avg(close_time) AS avg_close from order_mt4 as o join account_opt a on o.source = a.source and o.login = a.login where a.client_id = 100600"
}



###
#"sql": "select o.* from order_mt4 as o join account_opt a on o.source = a.source and o.login = a.login where a.client_id = 100600 order by o.close_time DESC limit 10"
# This query retrieves all columns from the `order_mt4` table for orders that are associated with a specific client ID (100600). It performs a join with the `account_opt` table to match orders based on their source and login information. The results are ordered by the close time of the orders in descending order, meaning the most recently closed orders will appear first. The `LIMIT 10` clause restricts the output to the top 10 records, providing a snapshot of the most recent orders for that client.
# DuckDB elapsed time: 7231 ms
# MariaDB elapsed time: manually stopped after 12 m
POST {{url}}/v1/sql/query
accept: application/json
x-api-key: {{apiKey}}
Content-Type: application/json

{
  "sql": "select a.client_id, o.* from order_mt4 as o join account_opt a on o.source = a.source and o.login = a.login where a.client_id = 100600 order by o.close_time DESC limit 10"
}

###
